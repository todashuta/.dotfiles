#!/bin/bash

[[ $1 == -h || $1 == --help ]] && exec claude --help

export ANTHROPIC_AUTH_TOKEN=ollama
export ANTHROPIC_API_KEY=""
export ANTHROPIC_BASE_URL=http://localhost:11434

arg_model_found=false

for opt in "$@"; do
	case $opt in
		--model=*) arg_model_found=true ;;
	esac
done

if [[ $arg_model_found = true ]]; then
	exec claude "$@"
else
	model=$(curl -s "$ANTHROPIC_BASE_URL/api/tags" | jq -r '.models[].name' | sort | peco)
	[[ -z "$model" ]] && exit 1
	exec claude --model="$model" "$@"
fi
