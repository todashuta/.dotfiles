#!/bin/bash

ollama_exe="$HOME/devel/ollama/ollama"
models=$("$ollama_exe" list | awk 'NR > 1 {print $1}')

err() {
	echo "$@" 1>&2
}

if [[ $# -eq 0 ]]; then
	err "Please specify a model name."
	err "Available Models:"
	err $models
	exit 1
fi

modelname="$1" ; shift
ok=false

for m in $models; do
	[[ $modelname = $m ]] && ok=true
done

if [[ $ok = false ]]; then
	err "Unknown model name: $modelname."
	err "Available Models:"
	err $models
	exit 1
fi

exec "$ollama_exe" launch claude --model="$modelname" -- "$@"
